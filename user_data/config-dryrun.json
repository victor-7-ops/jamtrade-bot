{
    "$schema": "https://schema.freqtrade.io/schema.json",

    "//  ───────────────────────────────────────────────────────────────": "",
    "//  DRY-RUN CONFIG — PAPER TRADING ON A LIVE FEED, NO REAL MONEY": "",
    "//  dry_run is TRUE. The bot connects to the real Binance price feed": "",
    "//  but every trade is simulated against a fake wallet. This is the": "",
    "//  safe way to 'try it in the real market'. Leave dry_run TRUE until": "",
    "//  you have weeks/months of consistent results.": "",
    "//  ───────────────────────────────────────────────────────────────": "",

    "dry_run": true,
    "dry_run_wallet": 1000,

    "max_open_trades": 3,
    "stake_currency": "USDT",
    "stake_amount": 100,
    "tradable_balance_ratio": 0.99,
    "fiat_display_currency": "USD",
    "timeframe": "4h",

    "cancel_open_orders_on_exit": false,
    "trading_mode": "spot",
    "margin_mode": "",

    "unfilledtimeout": {
        "entry": 10,
        "exit": 10,
        "exit_timeout_count": 0,
        "unit": "minutes"
    },

    "entry_pricing": {
        "price_side": "other",
        "use_order_book": true,
        "order_book_top": 1,
        "price_last_balance": 0.0,
        "check_depth_of_market": {
            "enabled": false,
            "bids_to_ask_delta": 1
        }
    },

    "exit_pricing": {
        "price_side": "other",
        "use_order_book": true,
        "order_book_top": 1
    },

    "exchange": {
        "//  No API keys are needed for dry-run with public data.": "",
        "//  When you eventually go live, you'd add key/secret here AND": "",
        "//  flip dry_run to false — but not before paper trading.": "",
        "name": "kraken",
        "key": "",
        "secret": "",
        "ccxt_config": {},
        "ccxt_async_config": {},
        "pair_whitelist": [
            "BTC/USDT",
            "ETH/USDT",
            "SOL/USDT"
        ],
        "pair_blacklist": [
            "BNB/.*",
            ".*UP/USDT",
            ".*DOWN/USDT",
            ".*BULL/USDT",
            ".*BEAR/USDT"
        ]
    },

    "pairlists": [
        {
            "method": "StaticPairList"
        }
    ],

    "//  Telegram is OPTIONAL. Leave enabled=false to skip it entirely.": "",
    "//  To get alerts: create a bot via @BotFather, get your chat id,": "",
    "//  set enabled=true and fill token/chat_id below.": "",
    "telegram": {
        "enabled": true,
        "token": "${TG_TOKEN}",
        "chat_id": "${TG_CHAT_ID}"
    },

    "//  The REST API + web UI. Change the password before exposing it.": "",
    "api_server": {
        "enabled": false,
        "listen_ip_address": "127.0.0.1",
        "listen_port": 8080,
        "verbosity": "error",
        "enable_openapi": false,
        "jwt_secret_key": "y9HNJTk28OGpZjteEC3IwPuvbSKzsmh6DxRMFWQYaVLU51nc",
        "ws_token": "wsTok3n-ChangeBeforeExposing-xR9mQ2vL",
        "CORS_origins": [],
        "username": "freqtrader",
        "password": "CHANGE_THIS_PASSWORD"
    },

    "bot_name": "StrategyLab-DryRun",
    "initial_state": "running",
    "force_entry_enable": false,

    "internals": {
        "process_throttle_secs": 5
    }
}
